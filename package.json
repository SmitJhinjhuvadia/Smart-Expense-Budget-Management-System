{
  "name": "smart-expense-budget-system",
  "version": "1.0.0",
  "description": "Smart Expense & Budget Management System",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
